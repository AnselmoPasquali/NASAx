<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- Sfondo stellare -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.45"
        android:src="@drawable/stars_background"
        android:contentDescription="@string/background_stars" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ── HEADER ───────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="52dp"
                android:paddingBottom="18dp">

                <!-- Title + subtitle -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAPOD"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/apod_header_title"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/apod_header_subtitle"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="3dp" />

                </LinearLayout>

                <!-- Calendar icon -->
                <ImageView
                    android:id="@+id/ivCalendar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_calendar"
                    android:contentDescription="Search by date"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@android:color/transparent" />

                <!-- NASA logo (tap to refresh) -->
                <ImageView
                    android:id="@+id/ivNasaLogo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/nasa_logo"
                    android:contentDescription="NASA Official"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@android:color/transparent" />

            </LinearLayout>

            <!-- ── APOD IMAGE CARD ───────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginBottom="0dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="@color/card_apod"
                app:strokeWidth="1dp"
                app:strokeColor="#2A3A6A">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="480dp">

                    <ImageView
                        android:id="@+id/ivApod"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:contentDescription="@string/apod_image"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Dark scrim -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#33000000" />

                    <!-- Play button -->
                    <ImageView
                        android:id="@+id/ivPlayButton"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_circle"
                        android:visibility="gone"
                        android:clickable="false"
                        android:focusable="false" />

                    <!-- Date (bottom-right) -->
                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="12dp"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:textStyle="italic" />

                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── TITLE + ACTIONS ───────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="18dp"
                android:paddingTop="14dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:lineSpacingExtra="2dp" />

                <!-- Share -->
                <ImageView
                    android:id="@+id/btnShare"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="18dp"
                    android:src="@drawable/ic_share"
                    android:contentDescription="Share"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@android:color/transparent" />

                <!-- Favourites heart -->
                <ImageView
                    android:id="@+id/btnFavorites"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="18dp"
                    android:src="@drawable/ic_heart_outline"
                    android:contentDescription="@string/add_to_favorites"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@android:color/transparent" />

            </LinearLayout>

            <!-- ── EXPLANATION CARD ──────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/card_apod"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A3A6A">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvExplanation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:lineSpacingExtra="5dp"
                        android:textColor="#DDDDEE"
                        android:maxLines="8"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvReadMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/read_more"
                        android:textColor="@color/accent_apod"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:layout_marginTop="10dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
